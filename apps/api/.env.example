# Environment variables for the API

# Server
PORT=3001
NODE_ENV=development

# Redis (Cache & Queues)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mauromera?schema=public"
DATABASE_URL_BASE="postgresql://user:password@localhost:5432"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=7

# S3/Minio Storage
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="mauro-web"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_PUBLIC_URL="http://localhost:9000"

# Mercado Pago
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# SMTP Configuration (Email)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="noreply@mauromera.com"
SMTP_PASS="tu_contraseña_aqui"
SMTP_FROM="Mauro Mera <noreply@mauromera.com>"
