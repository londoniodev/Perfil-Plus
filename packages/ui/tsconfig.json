{
    "compilerOptions": {
        "target": "es2019",
        "module": "esnext",
        "lib": [
            "es2019",
            "dom"
        ],
        "declaration": true,
        "strict": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src"
    ]
}