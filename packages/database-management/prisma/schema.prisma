// This is the MANAGEMENT schema - separate from tenant schemas
// Contains platform-level data: Tenants, SuperAdmin users

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ TENANT MANAGEMENT ============
// Using String instead of enum for database compatibility

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String?  // Display name: "Daniela Coach" - optional for legacy rows
  slug      String   @unique // Subdomain/identifier: "daniela"
  dbName    String   // Database name: "tenants_daniela"
  status    String   @default("ACTIVE") // DEPLOYING, ACTIVE, SUSPENDED, DELETED
  plan      String   @default("free") // free, pro, enterprise
  
  // Metadata
  ownerEmail String?     // Contact email
  notes      String?     @db.Text
  features   String[]    @default([]) // Array de features activas: ['shop', 'blog']
  design     Json?       @default("{\"primary\": \"zinc\", \"radius\": 0.5, \"density\": \"default\"}") // Branding config
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now()) @updatedAt

  @@index([status])
  @@index([slug])
}

// ============ PLATFORM AUTHENTICATION ============

model PlatformUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String?  // optional
  role      String   @default("SUPERADMIN") // SUPERADMIN, SUPPORT
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
