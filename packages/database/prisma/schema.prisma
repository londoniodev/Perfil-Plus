// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ TENANT CONFIGURATION ============
model Tenant {
  id         String   @id @default(cuid())
  slug       String   @unique
  dbName     String
  name       String?
  status     String   @default("ACTIVE")
  plan       String   @default("free")
  ownerEmail String?
  notes      String?

  // Configuration
  design     Json?    // jsonb matches Json
  features   String[] // text[] matches String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones inversas
  users           User[]
  posts           Post[]
  categories      Category[]
  tags            Tag[]
  products        Product[]
  productVariants ProductVariant[]
  orders          Order[]
  tables          Table[]
  modifierGroups  ModifierGroup[]
  modifiers       Modifier[]
  storeSettings   StoreSettings[]
  leads           Lead[]
  themes          Theme[]
  courses         Course[]
  systemSettings  SystemSetting[]
  // Inventario
  warehouses      Warehouse[]
  inventoryItems  InventoryItem[]
  inventoryMovements InventoryMovement[]
  recipes         Recipe[]
  inventoryCounts InventoryCount[]
}

// ============ USUARIOS Y AUTH ============
enum Role {
  USER
  ADMIN
  WAITER    // Mesero: solo pedidos
  KITCHEN   // Cocina: solo comandas (KDS)
  CASHIER   // Caja: POS, mesas, menú, caja
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  password      String
  name          String
  role          Role      @default(USER)
  avatar        String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Account Lockout - Seguridad
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Relaciones
  tenant                  Tenant    @relation(fields: [tenantId], references: [id])
  subscription            Subscription?
  purchases               Purchase[]
  progress                UserProgress[]
  evaluations             EvaluationResult[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  orders                  Order[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique  // Hash del token
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique  // Hash del token
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============ SUSCRIPCIONES ============
enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique
  status            SubscriptionStatus @default(PENDING)
  mpSubscriptionId  String?            // ID de Mercado Pago
  mpPayerId         String?            // ID del pagador en MP
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ BLOG ============
model Post {
  id              String    @id @default(cuid())
  tenantId        String
  title           String
  slug            String
  excerpt         String
  content         String    @db.Text
  coverImage      String?
  isPremium       Boolean   @default(false)
  published       Boolean   @default(false)
  publishedAt     DateTime?
  authorName      String    @default("Mauricio Mera")
  
  // SEO fields
  metaTitle       String?
  metaDescription String?   @db.VarChar(160)
  
  // Calculated fields
  readingTime     Int?      // Minutos estimados de lectura
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  categories      CategoriesOnPosts[]
  tags            TagsOnPosts[]
  attachments     PostAttachment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, isPremium])
}

model Category {
  id       String @id @default(cuid())
  tenantId String
  name     String
  slug     String
  
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  posts    CategoriesOnPosts[]
  products CategoriesOnProducts[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
}

model CategoriesOnPosts {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model Tag {
  id       String @id @default(cuid())
  tenantId String
  name     String
  
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  posts    TagsOnPosts[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TagsOnPosts {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostAttachment {
  id        String   @id @default(cuid())
  postId    String
  name      String
  fileUrl   String
  fileType  String   // pdf, image, etc.
  fileSize  Int      // Size in bytes
  isPublic  Boolean  @default(true) // false = stored in private bucket
  createdAt DateTime @default(now())
  
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@index([postId])
}

// ============ LMS ============
model Theme {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  slug        String
  description String   @db.Text
  coverImage  String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  courses     Course[]
  evaluation  Evaluation?

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, order])
}

model Course {
  id          String   @id @default(cuid())
  tenantId    String
  themeId     String
  title       String
  slug        String
  description String   @db.Text
  coverImage  String?
  order       Int      @default(0)
  isFree      Boolean  @default(false)  // Cursos gratuitos vs premium
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  theme       Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([themeId, order])
  @@index([published, isFree])
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  slug        String
  content     String   @db.Text
  videoUrl    String?  // URL de video en Minio
  duration    Int?     // Duración en segundos
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    UserProgress[]
  attachments LessonAttachment[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model LessonAttachment {
  id        String   @id @default(cuid())
  lessonId  String
  name      String
  fileUrl   String
  fileType  String   // pdf, doc, etc.
  fileSize  Int      // Size in bytes
  createdAt DateTime @default(now())
  
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@index([lessonId])
}

model Evaluation {
  id           String   @id @default(cuid())
  themeId      String   @unique
  title        String
  description  String?
  passingScore Int      @default(70)  // Porcentaje mínimo para aprobar
  timeLimit    Int?     // Tiempo límite en minutos (opcional)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  theme     Theme      @relation(fields: [themeId], references: [id], onDelete: Cascade)
  questions Question[]
  results   EvaluationResult[]
}

model Question {
  id           String   @id @default(cuid())
  evaluationId String
  question     String   @db.Text
  image        String?  // URL de imagen en Minio (opcional)
  options      Json     // Array de opciones: [{id, text}]
  correctId    String   // ID de la opción correcta
  order        Int      @default(0)

  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId, order])
}

model EvaluationResult {
  id           String   @id @default(cuid())
  userId       String
  evaluationId String
  score        Int      // Porcentaje obtenido
  passed       Boolean
  answers      Json     // Respuestas del usuario
  timeTaken    Int?     // Tiempo en segundos
  completedAt  DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([userId, evaluationId])
  @@index([userId])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  watchedTime Int       @default(0)  // Segundos vistos
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ============ E-BOOKS ============
// ============ E-BOOK/PURCHASE DEPRECATION NOTES ============
// Ebook model deleted. Purchase model deprecated in favor of Order system.
// Keeping Purchase tentatively if needed for easy migration, but removing Ebook relation.

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  // ebookId removed - legacy
  productId     String?  // Optional migration field
  mpPaymentId   String?
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("pending")
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // No relation to deleted Ebook model

  @@index([userId])
  @@index([status])
}

// ============ CONFIGURACIÓN DE TIENDA ============
model StoreSettings {
  id            String   @id @default(cuid())
  tenantId      String
  
  // Mercado Pago - Credenciales dinámicas
  mpAccessToken String?  @db.Text
  mpPublicKey   String?  @db.Text
  
  // Configuraciones adicionales
  storeName     String?
  storeEmail    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ============ RESTAURANTE: MESA Y ZONAS ============
model Table {
  id        String   @id @default(cuid())
  tenantId  String
  label     String   // "Mesa 1", "Barra 2"
  capacity  Int      @default(4)
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE
  x         Int      @default(0) // Posición X en plano (futuro)
  y         Int      @default(0) // Posición Y en plano (futuro)
  
  // QR
  qrCode    String?  // URL o código único

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}



// ============ E-COMMERCE: PRODUCTOS MULTI-TIPO ============

// Enum: Tipo de producto
enum ProductType {
  DIGITAL   // E-books, cursos digitales, etc.
  PHYSICAL  // Gafas, suplementos, obras de arte, etc.
  SERVICE   // Consultorías, mentorías
  RESTAURANT // Platos, bebidas, menú del día
}

// Modelo: Producto (Base)
model Product {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  slug           String
  description    String      @db.Text
  productType    ProductType
  basePrice      Decimal     @db.Decimal(10, 2)
  images         String[]
  specs          Json?
  
  // Digital Product Fields
  digitalFileUrl String?     // Privado (Minio)
  previewUrl     String?     // Público (Minio)

  // Operativo Restaurante
  isAvailable    Boolean     @default(true) // Kill switch operativo

  published      Boolean     @default(false)
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relaciones
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  variants       ProductVariant[]
  modifierGroups ModifierGroup[]
  categories     CategoriesOnProducts[]
  likes          ProductLike[]
  comments       ProductComment[]
  recipe         Recipe?
  
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, productType])
  @@index([published, isAvailable]) // Optimizacion Menu publico
}

model CategoriesOnProducts {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

// ============ SOCIAL FEATURES (Instagram-style) ============
model ProductLike {
  id        String   @id @default(cuid())
  productId String
  userPhone String   // Acts as user ID for guests
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userPhone])
  @@index([productId])
}

model ProductComment {
  id        String   @id @default(cuid())
  productId String
  userPhone String   // Acts as user ID for guests
  userName  String?  // Optional name provided by user
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  // Moderation/Status
  isApproved Boolean @default(true) 

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Modelo: Variante de Producto (Lo que realmente se compra)
model ProductVariant {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  sku         String
  name        String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  attributes  Json?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([productId])
}

// ============ RESTAURANTE: MODIFICADORES ============

model ModifierGroup {
  id          String     @id @default(cuid())
  tenantId    String
  name        String     // "Elige tu acompañamiento"
  minSelect   Int        @default(0)
  maxSelect   Int        @default(1)
  productId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifiers   Modifier[]

  @@index([tenantId])
  @@index([productId])
}

model Modifier {
  id              String   @id @default(cuid())
  tenantId        String
  name            String   // "Papas Fritas", "Sin cebolla"
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)
  stock           Int?     // null = sin límite de inventario
  isAvailable     Boolean  @default(true) // Kill switch operativo
  groupId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItems      OrderItemModifier[]

  @@index([tenantId])
  @@index([groupId])
}

// ============ ÓRDENES DE COMPRA ============

enum OrderStatus {
  PENDING    // Esperando pago
  APPROVED   // Pago aprobado
  PROCESSING // En preparación (físicos)
  PREPARING  // En cocina (restaurante)
  READY      // Listo para servir (restaurante)
  SERVED     // Servido en mesa (restaurante)
  SHIPPED    // Enviado (físicos)
  DELIVERED  // Entregado/Completado
  CANCELLED  // Cancelado
  REFUNDED   // Reembolsado
}

enum OrderType {
  DINE_IN    // Comer en mesa
  TAKE_AWAY  // Para llevar (recogida)
  DELIVERY   // Domicilio
}

model Order {
  id            String      @id @default(cuid())
  tenantId      String
  userId        String?     // Opcional para Guest/Mesa
  orderNumber   String
  totalAmount   Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  orderType     OrderType   @default(DINE_IN)
  mpPaymentId   String?     // ID de Mercado Pago
  shippingData  Json?       // { "address": "...", "city": "..." }
  tableNumber   String?     // Número de mesa (solo DINE_IN)
  guestCount    Int?        @default(1) // Cantidad de personas por mesa (DINE_IN)
  
  // Guest / CRM fields
  customerName  String?
  customerPhone String?
  notes         String?     // Notas generales de la orden

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relaciones
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  user          User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  payments      Payment[]
  deliveryAnalytics OrderDeliveryAnalytics?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([orderType])
  @@index([status, createdAt]) // Optimizacion dashboard/admin queries
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int      @default(1)
  price       Decimal  @db.Decimal(10, 2)  // Precio unitario calculado server-side
  isPaid      Boolean  @default(false)     // Control de pagos parciales
  productName String   // Snapshot: nombre del producto al momento de compra
  variantName String?  // Snapshot: nombre de la variante (ej: "Rojo XL")
  notes       String?  // "Sin sal", "Alergia al maní", "Salsa aparte"
  isPrepared  Boolean  @default(false) // Control de KDS
  createdAt   DateTime @default(now())

  // Relaciones
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant    ProductVariant      @relation(fields: [variantId], references: [id])
  modifiers  OrderItemModifier[]

  @@index([orderId])
  @@index([variantId])
  @@index([orderId, isPrepared]) // Optimizacion KDS filtering
}

model OrderItemModifier {
  id              String   @id @default(cuid())
  orderItemId     String
  modifierId      String
  modifierName    String   // Snapshot del nombre al momento de compra
  priceAdjustment Decimal  @db.Decimal(10, 2) // Snapshot del precio
  quantity        Int      @default(1)         // "Doble Extra Queso" = 2

  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier        Modifier  @relation(fields: [modifierId], references: [id])



  @@index([orderItemId])
}

// Modelo: Pagos (Parciales o Totales)
model Payment {
  id            String   @id @default(cuid())
  orderId       String
  amount        Decimal  @db.Decimal(10, 2)
  method        String   // 'CASH', 'CARD', 'TRANSFER', 'OTHER'
  reference     String?  // Auth code, transaction ID
  createdAt     DateTime @default(now())

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
}

// ============ CRM ============
model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  email     String?
  name      String?
  phone     String?
  source    String?  // Origen (Facebook, Google, etc.)
  notes     String?  @db.Text
  status    String   @default("new") // new, contacted, converted, lost
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ============ ANALÍTICAS DE ENTREGA ============
model OrderDeliveryAnalytics {
  id              String    @id @default(cuid())
  orderId         String    @unique
  pendingAt       DateTime  @default(now())
  preparingAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  timeToPrepare   Int?      // Segundos entre pending -> preparing
  timeToShip      Int?      // Segundos entre preparing -> shipped
  timeToDeliver   Int?      // Segundos entre shipped -> delivered
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============ CONFIGURACIÓN DEL SISTEMA (MULTI-TENANT) ============
model SystemSetting {
  id          String   @id @default(cuid())
  tenantId    String
  key         String   // Ej: "SMTP_CONFIG"
  value       Json     // Ej: { host: "...", user: "..." }
  isPublic    Boolean  @default(false)
  
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ============ INVENTARIO ============

enum InventoryUnit {
  KG   // Kilogramos
  GR   // Gramos
  LT   // Litros
  ML   // Mililitros
  UN   // Unidades
}

enum MovementType {
  ENTRY      // Compra / entrada manual
  EXIT       // Salida manual
  SALE       // Descuento por venta
  ADJUSTMENT // Ajuste por conteo físico
  TRANSFER   // Traspaso entre almacenes
}

enum AdjustmentType {
  MERMA // Desperdicio esperado
  FUGA  // Robo o error
}

enum CountStatus {
  DRAFT     // En progreso
  COMPLETED // Finalizado
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // "Bodega Central", "Cocina", "Barra"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  stock     WarehouseStock[]
  movements InventoryMovement[]
  counts    InventoryCount[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model InventoryItem {
  id        String        @id @default(cuid())
  tenantId  String
  name      String        // "Carne molida", "Pan brioche"
  sku       String?
  unit      InventoryUnit @default(UN)
  avgCost   Decimal       @default(0) @db.Decimal(10, 4)
  lastCost  Decimal       @default(0) @db.Decimal(10, 4)
  minStock  Decimal       @default(0) @db.Decimal(10, 3) // Punto de reorden
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  stock       WarehouseStock[]
  movements   InventoryMovement[]
  ingredients RecipeIngredient[]
  countLines  InventoryCountLine[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model WarehouseStock {
  id              String   @id @default(cuid())
  warehouseId     String
  inventoryItemId String
  currentStock    Decimal  @default(0) @db.Decimal(10, 3)
  updatedAt       DateTime @updatedAt

  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, inventoryItemId])
}

model InventoryMovement {
  id              String       @id @default(cuid())
  tenantId        String
  inventoryItemId String
  warehouseId     String
  type            MovementType
  quantity        Decimal      @db.Decimal(10, 3) // + entrada, - salida
  unitCost        Decimal?     @db.Decimal(10, 4) // Precio unitario (en ENTRY)
  reason          String?      // "Compra semanal", "Venta ORD-2026-0042"
  reference       String?      // orderId o countId
  createdBy       String?      // userId
  createdAt       DateTime     @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([inventoryItemId])
  @@index([warehouseId])
  @@index([type, createdAt])
}

// ============ RECETAS / BOM ============

model Recipe {
  id        String   @id @default(cuid())
  tenantId  String
  productId String   @unique // 1 Product = 1 Recipe
  yield     Int      @default(1) // Porciones que salen
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  product     Product            @relation(fields: [productId], references: [id])
  ingredients RecipeIngredient[]

  @@index([tenantId])
}

model RecipeIngredient {
  id              String  @id @default(cuid())
  recipeId        String
  inventoryItemId String
  quantity        Decimal @db.Decimal(10, 3) // Cantidad por yield
  wasteFactor     Decimal @default(1) @db.Decimal(4, 2) // 1.05 = 5% desperdicio

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([recipeId, inventoryItemId])
}

// ============ CONTEO FÍSICO ============

model InventoryCount {
  id          String      @id @default(cuid())
  tenantId    String
  warehouseId String
  status      CountStatus @default(DRAFT)
  countedBy   String?     // userId
  notes       String?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  lines     InventoryCountLine[]

  @@index([tenantId])
  @@index([warehouseId])
}

model InventoryCountLine {
  id              String          @id @default(cuid())
  countId         String
  inventoryItemId String
  systemStock     Decimal         @db.Decimal(10, 3) // Snapshot del stock teórico
  countedStock    Decimal?        @db.Decimal(10, 3) // Lo que contó el usuario
  difference      Decimal?        @db.Decimal(10, 3) // Calculado: counted - system
  adjustmentType  AdjustmentType? // MERMA o FUGA

  count         InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id])

  @@unique([countId, inventoryItemId])
}
