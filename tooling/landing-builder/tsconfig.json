{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@alvarosky/ui/*": ["../../packages/ui/src/*"],
      "@alvarosky/shared/*": ["../../packages/shared/src/*"],
      "@alvarosky/features/*": ["../../packages/features/src/*"],
      "@/*": ["../../apps/_template/src/*"],
      "next/image": ["src/mocks/next-image.tsx"],
      "next/link": ["src/mocks/next-link.tsx"],
      "next/font/google": ["src/mocks/next-font-google.tsx"],
      "framer-motion": ["src/mocks/framer-motion.tsx"],
      "lucide-react": ["src/mocks/lucide-react.tsx"],
      "@alvarosky/ui/toast": ["src/mocks/ui-toast.tsx"],
      "@/app/providers": ["src/mocks/app-providers.tsx"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
