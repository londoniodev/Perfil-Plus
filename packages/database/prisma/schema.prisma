generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  slug               String              @unique
  domain             String?             @unique
  dbName             String
  name               String?
  status             String              @default("ACTIVE")
  plan               String              @default("free")
  ownerEmail         String?
  notes              String?
  design             Json?
  features           String[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  categories         Category[]
  courses            Course[]
  deliveryDrivers    DeliveryDriver[]
  inventoryCounts    InventoryCount[]
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  leads              Lead[]
  modifiers          Modifier[]
  modifierGroups     ModifierGroup[]
  orders             Order[]
  posts              Post[]
  products           Product[]
  productVariants    ProductVariant[]
  recipes            Recipe[]
  storeSettings      StoreSettings[]
  systemSettings     SystemSetting[]
  tables             Table[]
  tags               Tag[]
  themes             Theme[]
  users              User[]
  waConversations    WaConversation[]
  waMessages         WaMessage[]
  waCustomers        WaCustomer[]
  waCarts            WaCart[]
  warehouses         Warehouse[]
}

model User {
  id                      String                   @id @default(cuid())
  email                   String
  password                String
  name                    String
  role                    Role                     @default(USER)
  avatar                  String?
  emailVerified           Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  failedLoginAttempts     Int                      @default(0)
  lockedUntil             DateTime?
  tenantId                String
  deliveryDriver          DeliveryDriver?
  emailVerificationTokens EmailVerificationToken[]
  evaluations             EvaluationResult[]
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  purchases               Purchase[]
  refreshTokens           RefreshToken[]
  subscription            Subscription?
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  progress                UserProgress[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  status           SubscriptionStatus @default(PENDING)
  mpSubscriptionId String?
  mpPayerId        String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id              String              @id @default(cuid())
  title           String
  slug            String
  excerpt         String
  content         String
  coverImage      String?
  isPremium       Boolean             @default(false)
  published       Boolean             @default(false)
  publishedAt     DateTime?
  authorName      String              @default("Mauricio Mera")
  metaTitle       String?
  metaDescription String?             @db.VarChar(160)
  readingTime     Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenantId        String
  categories      CategoriesOnPosts[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  attachments     PostAttachment[]
  tags            TagsOnPosts[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, isPremium])
}

enum CategoryType {
  PRODUCT
  BLOG
}

model Category {
  id       String                 @id @default(cuid())
  name     String
  slug     String
  type     CategoryType           @default(PRODUCT)
  tenantId String
  posts    CategoriesOnPosts[]
  products CategoriesOnProducts[]
  tenant   Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type, name])
  @@unique([tenantId, type, slug])
  @@index([tenantId])
}

model CategoriesOnPosts {
  postId     String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model Tag {
  id       String        @id @default(cuid())
  name     String
  tenantId String
  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  posts    TagsOnPosts[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TagsOnPosts {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostAttachment {
  id        String   @id @default(cuid())
  postId    String
  name      String
  fileUrl   String
  fileType  String
  fileSize  Int
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Theme {
  id          String      @id @default(cuid())
  title       String
  slug        String
  description String
  coverImage  String?
  order       Int         @default(0)
  published   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenantId    String
  courses     Course[]
  evaluation  Evaluation?
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, order])
}

model Course {
  id          String   @id @default(cuid())
  themeId     String
  title       String
  slug        String
  description String
  coverImage  String?
  order       Int      @default(0)
  isFree      Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  theme       Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([themeId, order])
  @@index([published, isFree])
}

model Lesson {
  id          String             @id @default(cuid())
  courseId    String
  title       String
  slug        String
  content     String
  videoUrl    String?
  duration    Int?
  order       Int                @default(0)
  published   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attachments LessonAttachment[]
  progress    UserProgress[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model LessonAttachment {
  id        String   @id @default(cuid())
  lessonId  String
  name      String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Evaluation {
  id           String             @id @default(cuid())
  themeId      String             @unique
  title        String
  description  String?
  passingScore Int                @default(70)
  timeLimit    Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  theme        Theme              @relation(fields: [themeId], references: [id], onDelete: Cascade)
  results      EvaluationResult[]
  questions    Question[]
}

model Question {
  id           String     @id @default(cuid())
  evaluationId String
  question     String
  image        String?
  options      Json
  correctId    String
  order        Int        @default(0)
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId, order])
}

model EvaluationResult {
  id           String     @id @default(cuid())
  userId       String
  evaluationId String
  score        Int
  passed       Boolean
  answers      Json
  timeTaken    Int?
  completedAt  DateTime   @default(now())
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, evaluationId])
  @@index([userId])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  watchedTime Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  mpPaymentId String?
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("pending")
  purchasedAt DateTime @default(now())
  productId   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model StoreSettings {
  id              String   @id @default(cuid())
  mpAccessToken   String?
  mpPublicKey     String?
  storeName       String?
  storeEmail      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenantId        String
  waAccessToken   String?
  waPhoneNumberId String?  @unique
  wabaId          String?  @unique
  deliveryFee     Decimal? @default(0) @db.Decimal(10, 2)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Table {
  id        String   @id @default(cuid())
  label     String
  capacity  Int      @default(4)
  status    String   @default("ACTIVE")
  x         Int      @default(0)
  y         Int      @default(0)
  qrCode    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Product {
  id             String                 @id @default(cuid())
  name           String
  slug           String
  description    String
  productType    ProductType
  basePrice      Decimal                @db.Decimal(10, 2)
  images         String[]
  specs          Json?
  published      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  digitalFileUrl String?
  isAvailable    Boolean                @default(true)
  previewUrl     String?
  tenantId       String
  categories     CategoriesOnProducts[]
  modifierGroups ModifierGroup[]
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  comments       ProductComment[]
  likes          ProductLike[]
  variants       ProductVariant[]
  recipe         Recipe?

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published, productType])
  @@index([published, isAvailable])
}

model CategoriesOnProducts {
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductLike {
  id        String   @id @default(cuid())
  productId String
  userPhone String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userPhone])
  @@index([productId])
}

model ProductComment {
  id         String   @id @default(cuid())
  productId  String
  userPhone  String
  userName   String?
  content    String
  createdAt  DateTime @default(now())
  isApproved Boolean  @default(true)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  sku        String
  name       String?
  price      Decimal     @db.Decimal(10, 2)
  stock      Int         @default(0)
  attributes Json?
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tenantId   String
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant     Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([productId])
}

model ModifierGroup {
  id        String     @id @default(cuid())
  name      String
  minSelect Int        @default(0)
  maxSelect Int        @default(1)
  productId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenantId  String
  modifiers Modifier[]
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([productId])
}

model Modifier {
  id              String              @id @default(cuid())
  name            String
  priceAdjustment Decimal             @default(0) @db.Decimal(10, 2)
  stock           Int?
  isAvailable     Boolean             @default(true)
  groupId         String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenantId        String
  group           ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  orderItems      OrderItemModifier[]

  @@index([tenantId])
  @@index([groupId])
}

model Order {
  id                String                  @id @default(cuid())
  userId            String?
  orderNumber       String
  totalAmount       Decimal                 @db.Decimal(10, 2)
  status            OrderStatus             @default(PENDING)
  mpPaymentId       String?
  shippingData      Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  customerName      String?
  customerPhone     String?
  notes             String?
  orderType         OrderType               @default(DINE_IN)
  tableNumber       String?
  tenantId          String
  guestCount        Int?                    @default(1)
  assignedAt        DateTime?
  deliverySequence  Int?
  driverId          String?
  customerEmail     String?
  identification    String?
  driver            DeliveryDriver?         @relation(fields: [driverId], references: [id])
  tenant            Tenant                  @relation(fields: [tenantId], references: [id])
  user              User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAnalytics OrderDeliveryAnalytics?
  items             OrderItem[]
  payments          Payment[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([orderType])
  @@index([driverId])
  @@index([status, createdAt])
  @@index([mpPaymentId])
}

model OrderItem {
  id          String              @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int                 @default(1)
  price       Decimal             @db.Decimal(10, 2)
  createdAt   DateTime            @default(now())
  productName String
  variantName String?
  isPaid      Boolean             @default(false)
  isPrepared  Boolean             @default(false)
  notes       String?
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant      @relation(fields: [variantId], references: [id])
  modifiers   OrderItemModifier[]

  @@index([orderId])
  @@index([variantId])
  @@index([orderId, isPrepared])
}

model OrderItemModifier {
  id              String    @id @default(cuid())
  orderItemId     String
  modifierId      String
  modifierName    String
  priceAdjustment Decimal   @db.Decimal(10, 2)
  quantity        Int       @default(1)
  modifier        Modifier  @relation(fields: [modifierId], references: [id])
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  reference String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Lead {
  id        String   @id @default(cuid())
  email     String?
  name      String?
  phone     String?
  source    String?
  notes     String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([source])
  @@index([createdAt])
}

model OrderDeliveryAnalytics {
  id            String    @id @default(cuid())
  orderId       String    @unique
  pendingAt     DateTime  @default(now())
  preparingAt   DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  timeToPrepare Int?
  timeToShip    Int?
  timeToDeliver Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedAt    DateTime?
  driverId      String?
  pickedUpAt    DateTime?
  timeToAssign  Int?
  timeToPickup  Int?
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model DeliveryDriver {
  id                  String       @id @default(cuid())
  tenantId            String
  userId              String       @unique
  vehicle             String?
  phone               String
  status              DriverStatus @default(OFFLINE)
  currentActiveOrders Int          @default(0)
  maxCapacity         Int          @default(3)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders              Order[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String
  value       Json
  isPublic    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Warehouse {
  id        String              @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  counts    InventoryCount[]
  movements InventoryMovement[]
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  stock     WarehouseStock[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model InventoryItem {
  id          String               @id @default(cuid())
  tenantId    String
  name        String
  sku         String?
  unit        InventoryUnit        @default(UN)
  avgCost     Decimal              @default(0) @db.Decimal(10, 4)
  lastCost    Decimal              @default(0) @db.Decimal(10, 4)
  minStock    Decimal              @default(0) @db.Decimal(10, 3)
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  countLines  InventoryCountLine[]
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  movements   InventoryMovement[]
  ingredients RecipeIngredient[]
  stock       WarehouseStock[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model WarehouseStock {
  id              String        @id @default(cuid())
  warehouseId     String
  inventoryItemId String
  currentStock    Decimal       @default(0) @db.Decimal(10, 3)
  updatedAt       DateTime      @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, inventoryItemId])
}

model InventoryMovement {
  id              String        @id @default(cuid())
  tenantId        String
  inventoryItemId String
  warehouseId     String
  type            MovementType
  quantity        Decimal       @db.Decimal(10, 3)
  unitCost        Decimal?      @db.Decimal(10, 4)
  reason          String?
  reference       String?
  createdBy       String?
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([inventoryItemId])
  @@index([warehouseId])
  @@index([type, createdAt])
  @@index([reference])
}

model Recipe {
  id          String             @id @default(cuid())
  tenantId    String
  productId   String             @unique
  yield       Int                @default(1)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  product     Product            @relation(fields: [productId], references: [id])
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  ingredients RecipeIngredient[]

  @@index([tenantId])
}

model RecipeIngredient {
  id              String        @id @default(cuid())
  recipeId        String
  inventoryItemId String
  quantity        Decimal       @db.Decimal(10, 3)
  wasteFactor     Decimal       @default(1) @db.Decimal(4, 2)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  recipe          Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, inventoryItemId])
}

model InventoryCount {
  id          String               @id @default(cuid())
  tenantId    String
  warehouseId String
  status      CountStatus          @default(DRAFT)
  countedBy   String?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id])
  lines       InventoryCountLine[]

  @@index([tenantId])
  @@index([warehouseId])
}

model InventoryCountLine {
  id              String          @id @default(cuid())
  countId         String
  inventoryItemId String
  systemStock     Decimal         @db.Decimal(10, 3)
  countedStock    Decimal?        @db.Decimal(10, 3)
  difference      Decimal?        @db.Decimal(10, 3)
  adjustmentType  AdjustmentType?
  count           InventoryCount  @relation(fields: [countId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])

  @@unique([countId, inventoryItemId])
}

model WaConversation {
  id            String               @id @default(cuid())
  tenantId      String
  customerPhone String
  status        WaConversationStatus @default(OPEN)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  messages      WaMessage[]

  @@unique([tenantId, customerPhone, status], name: "active_conversation", map: "WaConversation_active_conversation_idx")
  @@index([tenantId])
  @@index([customerPhone])
  @@index([tenantId, status])
}

model WaMessage {
  id             String         @id @default(cuid())
  conversationId String
  waMessageId    String         @unique
  role           WaMessageRole
  content        String
  createdAt      DateTime       @default(now())
  tenantId       String
  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([role])
}

model WaCustomer {
  id        String   @id @default(cuid())
  tenantId  String
  phone     String
  name      String?
  address   String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
}

model WaCart {
  id           String   @id @default(cuid()) // Format: wa-xxxx-yyyy
  tenantId     String
  customerPhone String?
  cartData     Json     // { items: [...], customerData: {...} }
  expiresAt    DateTime // Custom TTL, e.g., 24h
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, id])
  @@index([expiresAt])
}

